# Required if you want to run the cron API route
CRON_SECRET=change-me

# Postgres (Neon / Vercel Postgres)
DATABASE_URL=

# Clerk (email login)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: enables LLM-based ranking + tighter summaries
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: overrides the feed fetcher user-agent contact string
DIGEST_BOT_CONTACT=you@example.com

# Resend (daily digest emails)
RESEND_API_KEY=
EMAIL_FROM="NewsHub <news@yourdomain.com>"

# Public site URL used in emails
SITE_URL="https://your-domain.example"
